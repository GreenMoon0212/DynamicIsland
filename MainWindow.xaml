<Window x:Class="DynamicIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dynamic Island" Height="800" Width="900"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False" 
        ShowActivated="False" 
        Focusable="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual" Top="0"
        Deactivated="Window_Deactivated">
    
    <Window.Resources>
        <Style x:Key="ControlBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <CubicEase x:Key="IslandEase" EasingMode="EaseOut"/>
    </Window.Resources>

    <Grid Background="Transparent" Height="650" VerticalAlignment="Top"
          MouseEnter="Handle_MouseEnter" MouseLeave="Handle_MouseLeave">
    
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
            <Border x:Name="IslandBorder" x:FieldModifier="public"
                    Background="#FF111111" Height="55" Width="330" CornerRadius="27.5"
                    Cursor="Hand" MouseLeftButtonDown="Island_Click"
                    AllowDrop="True" Drop="Island_Drop" DragOver="Island_DragOver">
                
                <Border.Effect>
                    <DropShadowEffect x:Name="IslandGlow" 
                                      BlurRadius="65" 
                                      Color="LimeGreen" 
                                      Opacity="1" 
                                      ShadowDepth="0"
                                      RenderingBias="Performance"/>
                </Border.Effect>

                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="MenuSticky" Header="📌 固定在桌面" IsCheckable="True" Click="ToggleSticky_Click"/>
                        <MenuItem Header="🎨 設定顏色" Click="OpenColorPicker_Click"/>
                        <Separator/>
                        <MenuItem Header="❌ 離開程式" Click="Exit_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> 
                    </Grid.ColumnDefinitions>

                    <Border x:Name="AlbumArtBorder" Grid.Column="0" Width="35" Height="35" CornerRadius="8" Margin="0,0,10,0" VerticalAlignment="Center" Background="#33FFFFFF" Visibility="Collapsed">
                        <Image x:Name="AlbumArtImage" Stretch="UniformToFill">
                            <Image.Clip><RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,35,35"/></Image.Clip>
                        </Image>
                    </Border>

                    <Canvas x:Name="TextCanvas" Grid.Column="1" Width="140" Height="30" ClipToBounds="True" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="即將播放...." Foreground="White" FontSize="13" FontWeight="SemiBold" Canvas.Left="0" VerticalAlignment="Center"/>
                    </Canvas>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="CpuText" Text="CPU: 0% | 00°C" Foreground="#AAFFFFFF" FontSize="8.5"/>
                            <TextBlock x:Name="RamText" Text="RAM: 0%" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock x:Name="PingText" Text="Ping: 00ms" Foreground="#AAFFFFFF" FontSize="9"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="18">
                            <Rectangle x:Name="Bar1" Width="2.5" Height="8" Fill="LimeGreen" Margin="0.5,0" RadiusX="1" RadiusY="1"/>
                            <Rectangle x:Name="Bar2" Width="2.5" Height="12" Fill="LimeGreen" Margin="0.5,0" RadiusX="1" RadiusY="1"/>
                            <Rectangle x:Name="Bar3" Width="2.5" Height="6" Fill="LimeGreen" Margin="0.5,0" RadiusX="1" RadiusY="1"/>
                            <Rectangle x:Name="Bar4" Width="2.5" Height="10" Fill="LimeGreen" Margin="0.5,0" RadiusX="1" RadiusY="1"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ControlPanel" Background="#E61A1A1A" Width="480" Height="0" CornerRadius="30" Margin="0,15,0,0" Opacity="0" ClipToBounds="True"> 
                <StackPanel Orientation="Vertical" Margin="0,20,0,25">
                    <Grid Margin="45,10">
                        <ProgressBar x:Name="MusicProgress" Height="5" Background="#33FFFFFF" Foreground="LimeGreen" BorderThickness="0"/>
                        <Grid Margin="0,20,0,0">
                            <TextBlock x:Name="TimeCurrent" Text="00:00" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TimeTotal" Text="00:00" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <Button Content="⏮" Click="Prev_Click" Style="{StaticResource ControlBtnStyle}"/>
                        <Button x:Name="PlayPauseBtn" Content="▶" Click="PlayPause_Click" Style="{StaticResource ControlBtnStyle}" Margin="50,0" Width="60"/>
                        <Button Content="⏭" Click="Next_Click" Style="{StaticResource ControlBtnStyle}"/>
                    </StackPanel>
                    <Grid Margin="45,10">
                        <StackPanel>
                            <Slider x:Name="VolumeSlider" 
                                    Maximum="100" 
                                    Minimum="0" 
                                    ValueChanged="VolumeSlider_ValueChanged" 
                                    Margin="0,10" 
                                    Focusable="False"/>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="－" Click="BrightnessDown_Click" Width="40" Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                                    <Button Content="＋" Click="BrightnessUp_Click" Width="40" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Margin="5,0,0,0"/>
                                </StackPanel>
                                <Button x:Name="MuteBtn" Content="🔊 靜音" Click="Mute_Click" HorizontalAlignment="Right" Background="#44FFFFFF" Foreground="White" BorderThickness="0" Padding="10,2"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    <Border Margin="45,10,45,0" Background="#22FFFFFF" CornerRadius="12" Padding="12" PreviewMouseLeftButtonDown="DropZone_PreviewMouseLeftButtonDown" MouseMove="DropZone_MouseMove" MouseDown="DropZone_MouseDown" Cursor="Hand">
                        <TextBlock x:Name="DropZoneText" Text="📂 拖放檔案至此處中轉" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
