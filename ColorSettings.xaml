<Window x:Class="DynamicIsland.ColorSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="顏色設定" Height="500" Width="350" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="CenterScreen">

    <Border Background="#E61A1A1A" CornerRadius="20" BorderBrush="#33FFFFFF" BorderThickness="1">
        <StackPanel Margin="20">
            <TextBlock Text="自定義島嶼主題色" FontSize="18" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <xctk:ColorCanvas x:Name="ColorPicker" SelectedColorChanged="ColorPicker_SelectedColorChanged"
                              Background="Transparent" Foreground="White" UsingAlphaChannel="True"/>

            <TextBlock Text="日冕發光強度" Foreground="White" Margin="0,20,0,5"/>
            <Slider x:Name="GlowSlider" Minimum="0" Maximum="100" Value="20" 
                    ValueChanged="GlowSlider_ValueChanged" Cursor="Hand"/>

            <Button Content="確定" Margin="0,30,0,0" Height="35" Click="Close_Click"
                    Background="#FF0078D7" Foreground="White" Cursor="Hand" IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>